# .env.example - Production Environment Variables Template
# Copy this file to .env and configure based on your deployment

# ==============================================================================
# STORAGE
# ==============================================================================
# Host path untuk shared storage antara backend dan worker.
STORAGE_HOST_PATH=/srv/cekta/storage
# Host path read-only untuk sumber import dokumen/template jika dipakai.
DOKUMEN_IMPORT_SOURCE_HOST_PATH=/srv/cekta/import-source

# ==============================================================================
# DATABASE
# ==============================================================================
ConnectionStrings__SttsDbConnection=Server=db-stts.kampus.ac.id;Port=3306;Database=db_stts;User=your_stts_user;Password=your_stts_password;TreatTinyAsBoolean=false
# Compose backend akan override connection string ini ke service mysql-korektor di dalam repo yang sama.
ConnectionStrings__KorektorBukuDbConnection=Server=mysql-korektor;Port=3306;Database=db_korektor_buku;User=korektor_app;Password=change-me-app-password;TreatTinyAsBoolean=false
DB_PORT=3307
DB_NAME=db_korektor_buku
DB_USER=korektor_app
DB_PASSWORD=change-me-app-password
DB_ROOT_PASSWORD=change-me-root-password

# ==============================================================================
# AUTH
# ==============================================================================
Auth__JwtSecret=your-secret-key-min-32-characters-long-for-security
Auth__AccessTokenExpiryMinutes=15
Auth__RefreshTokenExpiryDays=7
Auth__AdminUsername=admin
Auth__ExternalApiUrl=https://ws.stts.edu/credential
Auth__ExternalApiToken=your-external-api-token
Auth__AppName=ta_korektor_buku

# ==============================================================================
# ADOBE PDF SERVICES
# ==============================================================================
Adobe__ApiBaseUrl=https://pdf-services-ue1.adobe.io

# ==============================================================================
# GEMINI
# ==============================================================================
Gemini__Model=gemma-3-27b-it
Gemini__Temperature=0.3
Gemini__TopP=0.95
Gemini__TopK=40
Gemini__MaxParallelBatches=4

# ==============================================================================
# EMAIL
# ==============================================================================
# Base URL frontend untuk link detail dokumen/buku di email
Email__DashboardUrl=https://frontend.kampus.ac.id
# SMTP
# Cocok untuk: Gmail pribadi (@gmail.com)
# PENTING: Gunakan App Password, BUKAN password akun Gmail biasa
# Cara mendapatkan App Password:
# 1. Aktifkan 2-Step Verification di akun Google
# 2. Buka https://myaccount.google.com/apppasswords
# 3. Generate App Password untuk "Mail" - "Windows Computer"
Email__SmtpHost=smtp.gmail.com
Email__SmtpPort=587
Email__UseSsl=true
Email__CheckCertificateRevocation=false
Email__SenderEmail=your-email@gmail.com
Email__SenderName=Validasi Format Buku TA/Tesis
Email__SenderPassword=your-gmail-app-password
Email__AdminRecipients=
# Development safety switch:
# Jika true, semua email akan diarahkan ke satu alamat aman
Email__OverrideRecipientsEnabled=false
Email__OverrideRecipientEmail=

# ==============================================================================
# OTHER
# ==============================================================================
AllowedHosts=*
Cors__AllowedOrigins__0=https://frontend.kampus.ac.id
Cors__AllowedOrigins__1=http://localhost:5173
Cors__AllowedOrigins__2=https://localhost:5173

# ==============================================================================
# SETUP INSTRUCTIONS
# ==============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and configure all variables above
# 3. Create host folders:
#    Linux: mkdir -p /srv/cekta/storage /srv/cekta/import-source
# 4. Run: docker compose up -d --build
