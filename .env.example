# .env.example - Environment Variables Template
# Copy this file to .env and configure based on your platform

# ==============================================================================
# DOCKER VOLUMES BASE PATH
# ==============================================================================
# This path will be used as storage root for dokumen and buku
# Structure: storage/dokumen/{nrp}/{id}/docx/ and storage/buku/{nrp}/{id}/docx/

# === WINDOWS ===
VOLUME_BASE_PATH=E:/docker-volumes/validasi-ta

# === LINUX ===
# VOLUME_BASE_PATH=/var/docker-volumes/validasi-ta

# === macOS ===
# VOLUME_BASE_PATH=~/docker-volumes/validasi-ta

# ==============================================================================
# SETUP INSTRUCTIONS
# ==============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and set VOLUME_BASE_PATH for your platform
# 3. Create the directory:
#    Windows:  mkdir E:\docker-volumes\validasi-ta
#    Linux:    mkdir -p /var/docker-volumes/validasi-ta
#    macOS:    mkdir -p ~/docker-volumes/validasi-ta
# 4. Run: docker-compose up --build
