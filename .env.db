# ==============================================================================
# Environment Variables for DB Docker Compose
# ==============================================================================
# Copy this file to .env.db and fill with production values
# Usage: docker compose -f docker-compose.db.yml --env-file .env.db up -d
# ==============================================================================

# Database Configuration
DB_PORT=3307
DB_NAME=db_korektor_buku
DB_USER=root
DB_PASSWORD=your_production_password
DB_ROOT_PASSWORD=your_root_password