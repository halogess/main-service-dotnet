# .env.example - Environment Variables Template
# Copy this file to .env and configure based on your platform

# ==============================================================================
# STORAGE
# ==============================================================================
# Windows
VOLUME_BASE_PATH=E:/docker-volumes/validasi-ta
# Linux: /var/docker-volumes/validasi-ta
# macOS: ~/docker-volumes/validasi-ta

# ==============================================================================
# DATABASE
# ==============================================================================
ConnectionStrings__SttsDbConnection=Server=host.docker.internal;Port=3306;Database=db_stts;User=root;Password=your_password;TreatTinyAsBoolean=false
ConnectionStrings__KorektorBukuDbConnection=Server=host.docker.internal;Port=3307;Database=db_korektor_buku;User=root;Password=your_password;TreatTinyAsBoolean=false

# ==============================================================================
# AUTH
# ==============================================================================
Auth__JwtSecret=your-secret-key-min-32-characters-long-for-security
Auth__AccessTokenExpiryMinutes=15
Auth__RefreshTokenExpiryDays=7
Auth__AdminUsername=admin
Auth__ExternalApiUrl=https://ws.stts.edu/credential
Auth__ExternalApiToken=your-external-api-token
Auth__AppName=ta_korektor_buku

# ==============================================================================
# ADOBE PDF SERVICES
# ==============================================================================
Adobe__ClientId=your-adobe-client-id
Adobe__ClientSecret=your-adobe-client-secret
Adobe__TokenUrl=https://pdf-services-ue1.adobe.io/token
Adobe__ApiBaseUrl=https://pdf-services-ue1.adobe.io

# ==============================================================================
# LOGGING
# ==============================================================================
Logging__LogLevel__Default=Information
Logging__LogLevel__MicrosoftAspNetCore=Warning

# ==============================================================================
# GEMINI
# ==============================================================================
Gemini__Model=gemma-3-27b-it
Gemini__StructuredModel=gemma-3-27b-it
Gemini__FallbackModel=gemma-3-27b-it
Gemini__ApiBaseUrl=https://generativelanguage.googleapis.com/v1beta
Gemini__Temperature=0.1
Gemini__TopP=0.8
Gemini__TopK=20
Gemini__MaxOutputTokens=6000
Gemini__MaxRetries=3
Gemini__RetryDelaySeconds=1,2,4
Gemini__DefaultRateLimitDelaySeconds=10
Gemini__TokensPerMinutePerKeyLimit=12000
Gemini__TokenWindowSeconds=60
Gemini__CacheHours=24
Gemini__MaxParseAttempts=3
Gemini__ParseRetryDelaySeconds=2
Gemini__BatchSize=20
Gemini__BatchDelaySeconds=3
Gemini__MaxParallelBatches=3
Gemini__MaxBatchRetries=2

# ==============================================================================
# OTHER
# ==============================================================================
AllowedHosts=*

# ==============================================================================
# SETUP INSTRUCTIONS
# ==============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and configure all variables above
# 3. Create storage directory:
#    Windows:  mkdir E:\docker-volumes\validasi-ta
#    Linux:    mkdir -p /var/docker-volumes/validasi-ta
#    macOS:    mkdir -p ~/docker-volumes/validasi-ta
# 4. Run: docker-compose up --build
