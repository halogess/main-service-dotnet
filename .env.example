# .env.example - Environment Variables Template
# Copy this file to .env and configure based on your platform

# ==============================================================================
# STORAGE
# ==============================================================================
# Windows
VOLUME_BASE_PATH=E:/docker-volumes/validasi-ta
# Linux: /var/docker-volumes/validasi-ta
# macOS: ~/docker-volumes/validasi-ta

# ==============================================================================
# DATABASE
# ==============================================================================
ConnectionStrings__SttsDbConnection=Server=host.docker.internal;Port=3306;Database=db_stts;User=root;Password=your_password
ConnectionStrings__KorektorBukuDbConnection=Server=host.docker.internal;Port=3307;Database=db_korektor_buku;User=root;Password=your_password

# ==============================================================================
# AUTH
# ==============================================================================
Auth__JwtSecret=your-secret-key-min-32-characters-long-for-security
Auth__AccessTokenExpiryMinutes=15
Auth__RefreshTokenExpiryDays=7
Auth__AdminUsername=admin
Auth__ExternalApiUrl=https://ws.stts.edu/credential
Auth__ExternalApiToken=your-external-api-token
Auth__AppName=ta_korektor_buku

# ==============================================================================
# ADOBE PDF SERVICES
# ==============================================================================
Adobe__ClientId=your-adobe-client-id
Adobe__ClientSecret=your-adobe-client-secret
Adobe__TokenUrl=https://pdf-services-ue1.adobe.io/token
Adobe__ApiBaseUrl=https://pdf-services-ue1.adobe.io

# ==============================================================================
# INTERNAL
# ==============================================================================
InternalApiKey=api_service

# ==============================================================================
# LOGGING
# ==============================================================================
Logging__LogLevel__Default=Information
Logging__LogLevel__MicrosoftAspNetCore=Warning

# ==============================================================================
# OTHER
# ==============================================================================
AllowedHosts=*

# ==============================================================================
# SETUP INSTRUCTIONS
# ==============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and configure all variables above
# 3. Create storage directory:
#    Windows:  mkdir E:\docker-volumes\validasi-ta
#    Linux:    mkdir -p /var/docker-volumes/validasi-ta
#    macOS:    mkdir -p ~/docker-volumes/validasi-ta
# 4. Run: docker-compose up --build
